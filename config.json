{
	"llm": {
		"provider": "custom",
		"extractionFormat": "custom",
		"gemini": {
			"apiKey": "",
			"model": "gemma-4-31b-it"
		},
		"ollama": {
			"baseUrl": "",
			"model": "gemma4:31b-cloud"
		},
		"custom": {
			"subProvider" : "openai",
			"openai" : {
				"endpoint" : "",
				"bridgedEndpoint" : "",
				"apiKey" : "",
				"model" : "gpt-5-mini"
			},
			"gemini" : {
				"endpoint" : "",
				"bridgedEndpoint" : "",
				"apiKey" : ""
			}
		},
		"hub": {
			"baseUrl": "",
			"apiKey": "",
			"model": "gpt-5.2-CIO"
		}
	},
	"graph": {
		"provider": "neo4j",
		"neo4j": {
			"instance": "myGraphDB",
			"uri": "bolt://localhost:7687",
			"database": "knowledgeGraph",
			"username": "neo4j",
			"password": ""
		}
	},
	"vector": {
		"provider": "chroma",
		"chroma": {
			"path": "http://localhost:8000",
			"tenant": "default_tenant",
			"database": "default_database",
			"nodeCollection": "kg_nodes",
			"relationCollection": "kg_relationships",
			"hitlCollection": "fleeting_notes_hitl"
		}
	},
	"embedding": {
		"provider": "chroma",
		"gemini": {
			"apiKey": "",
			"model": "gemini-embedding-001",
			"outputDimensionality": 768
		},
		"hub": {
			"baseUrl": "",
			"apiKey": "",
			"model": "embeddings",
			"encodingFormat": "float",
			"dimensions": 512,
			"batchSize": 64
		},
		"chroma" : {
			
		}
	},
	"rag": {
		"topK": 5,
		"depth": 4,
		"memory": {
			"enabled": true,
			"maxMessages": 12,
			"maxMessageChars": 2000,
			"rewriteQueryEnabled": true
		}
	},
	"ingestion": {
		"mode": "auto",
		"hitlDefaultUserName": "web-user",
		"contextEnabled": true,
		"contextTopK": 5,
		"contextDepth": 1
	},
	"schema": {
		"path": "./schema/graphSchema.json",
		"autoApplySuggestions": true
	},
	"logging": {
		"enabled": false,
		"directory": "./logs",
		"scopes": ["ingest", "ask"]
	},
	"prompts": {
		"extractionSystemPath": "./prompts/extraction-system.md",
		"extractionCustomSystemPath": "./prompts/extraction-system-custom.md",
		"answerSystemPath": "./prompts/answer-system.md",
		"contextFormatPath": "./prompts/context-format.md",
		"jobScannerSystemPath": "./prompts/job-scanner-system.md",
		"jobNuggetSystemPath": "./prompts/job-nugget-system.md"
	}
}
