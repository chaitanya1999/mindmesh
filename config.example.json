{
	"llm": {
		"provider": "gemini",
		"gemini": {
			"apiKey": "paste-your-api-key-here",
			"model": "gemini-2.5-flash"
		},
		"ollama": {
			"baseUrl": "http://localhost:11434",
			"model": "mistral",
			"think": false,
			"temperature": null
		},
		"custom": {
			"endpoint": "http://localhost:3001/llm"
		},
		"hub": {
			"baseUrl": "https://hub-proxy-service.thankfulfield-16b4d5d6.eastus.azurecontainerapps.io",
			"apiKey": "",
			"model": "gpt-4.1-nano"
		}
	},
	"graph": {
		"provider": "neo4j",
		"neo4j": {
			"instance": "myGraphDB",
			"uri": "bolt://localhost:7687",
			"database": "neo4j",
			"username": "neo4j",
			"password": "password"
		}
	},
	"vector": {
		"provider": "chroma",
		"chroma": {
			"path": "http://localhost:8000",
			"tenant": "default_tenant",
			"database": "default_database",
			"nodeCollection": "kg_nodes",
			"relationCollection": "kg_relationships",
			"hitlCollection": "fleeting_notes_hitl"
		}
	},
	"embedding": {
		"provider": "gemini",
		"gemini": {
			"apiKey": "reuse-gemini-api-key-or-leave-empty-to-use-llm-key",
			"model": "gemini-embedding-001",
			"outputDimensionality": 768
		},
		"hub": {
			"baseUrl": "leave-empty-to-use-llm-hub-base-url",
			"apiKey": "leave-empty-to-use-llm-hub-api-key",
			"model": "embeddings",
			"encodingFormat": "float",
			"dimensions": 512,
			"batchSize": 64
		},
		"chroma" : {
			
		}
	},
	"rag": {
		"topK": 5,
		"depth": 4,
		"memory": {
			"enabled": true,
			"maxMessages": 12,
			"maxMessageChars": 2000,
			"rewriteQueryEnabled": true
		}
	},
	"ingestion": {
		"mode": "auto",
		"hitlDefaultUserName": "web-user",
		"contextEnabled": true,
		"contextTopK": 5,
		"contextDepth": 1
	},
	"schema": {
		"path": "./schema/graphSchema.json",
		"autoApplySuggestions": false
	},
	"logging": {
		"enabled": false,
		"directory": "./logs",
		"scopes": ["ingest", "ask"]
	},
	"prompts": {
		"extractionCustomSystemPath": "./prompts/extraction-system-custom.md",
		"answerSystemPath": "./prompts/answer-system.md",
		"contextFormatPath": "./prompts/context-format.md",
		"jobScannerSystemPath": "./prompts/job-scanner-system.md",
		"jobNuggetSystemPath": "./prompts/job-nugget-system.md"
	}
}
